{
  "name": "platformio-mcp-server",
  "version": "1.0.0",
  "description": "A board-agnostic MCP server for PlatformIO embedded development - supports 1000+ boards across 30+ platforms",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "platformio-mcp-server": "build/index.js"
  },
  "files": [
    "build",
    "skills"
  ],
  "scripts": {
    "build:ui": "cd web && npm install && npm run build",
    "build": "npm run build:ui && tsc",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "platformio",
    "embedded",
    "iot",
    "arduino",
    "esp32",
    "stm32",
    "firmware",
    "embedded-systems",
    "cline",
    "ai"
  ],
  "author": "PlatformIO MCP Server Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "tree-kill": "^1.2.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.1.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/platformio-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/platformio-mcp-server/issues"
  },
  "homepage": "https://github.com/yourusername/platformio-mcp-server#readme"
}
